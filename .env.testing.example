# Copy to `.env.testing` for `php artisan migrate --env=testing` and other `--env=testing` commands.
# `php artisan test` / PHPUnit read `phpunit.xml`, which forces MySQL database `biz_buradayiz_test`
# (host, user, and password still come from your main `.env`). Create that database before running tests.

APP_NAME="Admin Panel (Testing)"
APP_ENV=testing
APP_KEY=base64:tlF9qO9r0CmywsVefQ8F2BrPwlfNOlmDKzsaJJiNwc0=
APP_DEBUG=true
APP_TIMEZONE=Europe/Istanbul
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=array

BCRYPT_ROUNDS=4

LOG_CHANNEL=single
LOG_LEVEL=debug

# Match PHPUnit (phpunit.xml): same MySQL database so artisan --env=testing and `php artisan test` stay in sync.
# Use the same DB_HOST / DB_USERNAME / DB_PASSWORD as `.env`, or set them only here.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=biz_buradayiz_test
DB_USERNAME=root
DB_PASSWORD=

# Optional: use SQLite in-memory instead — then change phpunit.xml back to DB_CONNECTION=sqlite and DB_DATABASE=:memory:
# DB_CONNECTION=sqlite
# DB_DATABASE=:memory:

SESSION_DRIVER=array
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync
CACHE_STORE=array

MAIL_MAILER=array

API_VERSION=v1

MEDIA_DISK=local
AUDITING_ENABLED=false
TELESCOPE_ENABLED=false

VERIMOR_WEBHOOK_TOKEN=test-webhook-token

# Optional: use a dedicated MySQL database for tests instead of SQLite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel_testing
# DB_USERNAME=root
# DB_PASSWORD=
